{
  "name": "obsidian-ontologize",
  "version": "0.2.0",
  "description": "Local-first ontology, inheritance-aware querying, validation, and relation maintenance for Obsidian Markdown vaults.",
  "keywords": [
    "obsidian",
    "plugin",
    "ontology",
    "markdown",
    "knowledge-graph"
  ],
  "license": "MIT",
  "author": "112345brian",
  "type": "module",
  "scripts": {
    "build": "jiti scripts/build.ts",
    "build:clean": "jiti scripts/build-clean.ts",
    "build:compile": "jiti scripts/build-compile.ts",
    "dev": "jiti scripts/dev.ts",
    "format": "jiti scripts/format.ts",
    "format:check": "jiti scripts/format-check.ts",
    "lint": "jiti scripts/lint.ts",
    "lint:fix": "jiti scripts/lint-fix.ts",
    "prepare": "jiti scripts/prepare.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "jiti scripts/version.ts"
  },
  "devDependencies": {
    "@codemirror/language": "6.11.2",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@tsconfig/strictest": "latest",
    "@types/node": "25.0.3",
    "jiti": "latest",
    "moment": "2.29.4",
    "obsidian": "latest",
    "obsidian-dev-utils": "latest",
    "obsidian-typings": "obsidian-public-latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "boolean": "npm:dry-uninstall",
    "dompurify": "3.2.4",
    "type-fest": "latest"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
